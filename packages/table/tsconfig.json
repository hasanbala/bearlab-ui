{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "es6", "ES2017"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "jsx": "react-jsx",
    "module": "esnext",
    "declaration": true,
    "outDir": "./dist",
    "declarationDir": "./dist/types",
    "rootDir": "./src",
    "composite": false,
    "paths": {
      "@bearlab/button": ["./packages/button/src"],
      "@bearlab/badge": ["./packages/badge/src"],
      "@bearlab/textarea": ["./packages/textarea/src"],
      "@bearlab/checkbox": ["./packages/checkbox/src"],
      "@bearlab/copy": ["./packages/copy/src"],
      "@bearlab/dropzone": ["./packages/dropzone/src"],
      "@bearlab/file-input": ["./packages/file-input/src"],
      "@bearlab/go-back": ["./packages/go-back/src"],
      "@bearlab/input": ["./packages/input/src"],
      "@bearlab/loading": ["./packages/loading/src"],
      "@bearlab/otp-form": ["./packages/otp-form/src"],
      "@bearlab/radio": ["./packages/radio/src"],
      "@bearlab/select": ["./packages/select/src"],
      "@bearlab/skeleton": ["./packages/skeleton/src"],
      "@bearlab/switch": ["./packages/switch/src"],
      "@bearlab/view-card": ["./packages/view-card/src"],
      "@bearlab/dropdown": ["./packages/dropdown/src"],
      "@bearlab/table": ["./packages/table/src"],
      "@bearlab/avatar": ["./packages/avatar/src"],
      "@bearlab/alert": ["./packages/alert/src"],
      "@bearlab/tab": ["./packages/tab/src"],
      "@bearlab/faq": ["./packages/faq/src"],
      "@bearlab/breadcrumb": ["./packages/breadcrumb/src"],
      "@bearlab/query-select": ["./packages/query-select/src"],
      "@bearlab/carousel": ["./packages/carousel/src"],
      "@bearlab/modal": ["./packages/modal/src"],
      "@bearlab/growl": ["./packages/growl/src"],
      "@bearlab/pricing": ["./packages/pricing/src"],
      "@bearlab/view-code": ["./packages/view-code/src"],
      "@bearlab/tag-input": ["./packages/tag-input/src"],
      "@bearlab/accordion": ["./packages/accordion/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.test.tsx"]
}
